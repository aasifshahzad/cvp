# Domain
# Set to the production domain
DOMAIN=your-production-domain.com

# Frontend host
# Used by the backend to generate links in emails
FRONTEND_HOST=https://pms-frontend-ten.vercel.app
# FRONTEND_HOST=https://475ce336-56fd-48e9-ac15-b78dbe63fed9.lovableproject.com

# Environment: local, staging, production
ENVIRONMENT=production

# Project & stack names
PROJECT_NAME="Spine Homeo"
STACK_NAME=spine-homeo

# Backend CORS origins
BACKEND_CORS_ORIGINS=https://pms-frontend-ten.vercel.app
# BACKEND_CORS_ORIGINS=https://475ce336-56fd-48e9-ac15-b78dbe63fed9.lovableproject.com

# Security
SECRET_KEY=spinehomeo
FIRST_SUPERUSER=admin@homoeomed.com
FIRST_SUPERUSER_PASSWORD=your-strong-password-here

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres (production database)
DATABASE_URL="postgresql://neondb_owner:npg_KXtcC8uzn5Da@ep-morning-shape-a1ozucn2-pooler.ap-southeast-1.aws.neon.tech/spinehomeo_database?sslmode=require&channel_binding=require"
