{
  "name": "cvp-monorepo",
  "version": "1.0.0",
  "description": "Homeopathy Clinic Management System - Monorepo",
  "scripts": {
    "dev": "concurrently --kill-others --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd cvp_backend && uv run uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd cvp_frontend && npm run dev",
    "generate-client": "cd cvp_frontend && npm run generate-client",
    "install:frontend": "cd cvp_frontend && npm install",
    "install:all": "npm install && npm run install:frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}